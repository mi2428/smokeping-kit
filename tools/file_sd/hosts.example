one.one.one.one       one.one.one.one      # probe=httping6       group=http-v6         provider=cloudflare  service=public_dns_http
quad9.net             quad9.net            # probe=httping6       group=http-v6         provider=quad9       service=public_dns_http

2001:4860:4860::8888  google-dns-v6-a      # probe=tcping6        group=tcp-dns-v6      provider=google      service=public_dns       port=53  target=[2001:4860:4860::8888]:53
2606:4700:4700::1111  cloudflare-dns-v6-a  # probe=tcping6        group=tcp-dns-v6      provider=cloudflare  service=public_dns       port=53  target=[2606:4700:4700::1111]:53
2620:fe::fe           quad9-dns-v6-a       # probe=tcping6        group=tcp-dns-v6      provider=quad9       service=public_dns       port=53  target=[2620:fe::fe]:53

