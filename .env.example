COMPOSE_PROJECT_NAME=smokeping-kit

# Compose will use the latest images by default. Set to missing or never if you
# want to avoid pulling on each start.
SMOKEPING_KIT_PULL_POLICY=always

PROMETHEUS_RETENTION=30d

# Default published entry point.
CADDY_HTTP_PORT=9000

# Used by docker-compose.no-caddy.yml when you opt out of Caddy.
PROMETHEUS_PORT=9090
PUSHGATEWAY_PORT=9091
ALERTMANAGER_PORT=9093
BLACKBOX_EXPORTER_PORT=9115
GRAFANA_PORT=3000

# External URLs used by Caddy path-based routing.
# Keep these as paths for local use, or set full URLs if you publish behind a domain.
PROMETHEUS_EXTERNAL_URL=/prometheus/
ALERTMANAGER_EXTERNAL_URL=http://localhost:9000/alertmanager/
GRAFANA_ROOT_URL=/grafana/

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme
GRAFANA_DEFAULT_THEME=system

# Installed at Grafana startup. Polystat gives dashboards a compact target
# status matrix. Set this to an empty value in .env for offline environments.
GRAFANA_PLUGINS=grafana-polystat-panel
